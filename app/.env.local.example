# Copy this file to .env.local and fill in your values
# BAAM System F — Chinese Restaurant Premium

# Site Configuration
NEXT_PUBLIC_DEFAULT_SITE=grand-pavilion
APP_ENV=dev
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_SITE_URL=http://localhost:3060

# Supabase (BAAM-Chinese-Restaurant project)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional environment-specific Supabase endpoints
SUPABASE_STAGING_URL=
NEXT_PUBLIC_SUPABASE_STAGING_URL=
SUPABASE_STAGING_SERVICE_ROLE_KEY=
SUPABASE_PROD_URL=
NEXT_PUBLIC_SUPABASE_PROD_URL=
SUPABASE_PROD_SERVICE_ROLE_KEY=

# Admin auth
JWT_SECRET=change-me-to-a-secure-random-string

# AI Content Generation (Pipeline B O5)
ANTHROPIC_API_KEY=
AI_CHAT_MODEL=claude-sonnet-4-6

# Email Configuration (Forms → DB + email)
RESEND_API_KEY=
RESEND_FROM=noreply@grandpavilionny.com
CONTACT_FALLBACK_TO=info@grandpavilionny.com
ALERT_TO=admin@grandpavilionny.com

# Google Services
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# IndexNow (SEO - Phase 3)
# INDEXNOW_KEY=

# Twilio (SMS notifications - optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
